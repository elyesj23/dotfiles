# ~/.ssh/config

Host *
	AddKeysToAgent yes
	UseKeychain yes
	ServerAliveInterval 60
	ServerAliveCountMax 3
	IdentitiesOnly yes
	HashKnownHosts yes

# GitHub
Host github.com
	HostName github.com
	User git
	IdentityFile ~/.ssh/id_ed25519

# GitLab
Host gitlab.com
	HostName gitlab.com
	User git
	IdentityFile ~/.ssh/id_ed25519
